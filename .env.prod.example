# ===========================
# Production Environment
# ===========================
# Copy this file to .env.prod and fill in your values
# NEVER commit this file to version control
# Use this template for production deployment

# Database Configuration
POSTGRES_DB=treinamentos_prod
POSTGRES_USER=postgres_prod_user
POSTGRES_PASSWORD=your_very_secure_production_password_here
POSTGRES_PORT=5432

# Connection String (.NET format)
ConnectionStrings__DefaultConnection=Server=postgres;Port=5432;Database=treinamentos_prod;User Id=postgres_prod_user;Password=your_very_secure_production_password_here;

# API Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:5000

# JWT Configuration (Use strong, random values)
Jwt__Secret=your_production_jwt_secret_key_here_minimum_32_characters_very_secure
Jwt__ExpirationHours=8
Jwt__Issuer=treinamentos-api
Jwt__Audience=treinamentos-frontend

# Google OAuth
Google__ClientId=your_production_google_client_id_here
Google__ClientSecret=your_production_google_client_secret_here

# SMTP Configuration (Email - Use production email service)
Smtp__Host=your_production_smtp_host_here
Smtp__Port=587
Smtp__User=your_production_email_here
Smtp__Password=your_production_email_password_here
Smtp__FromName=Plataforma de Treinamentos

# Videos Storage
Videos__StoragePath=/videos

# Application URLs (Production domain)
App__BaseUrl=https://your-production-domain.com

# Frontend Configuration
NEXTAUTH_URL=https://your-production-domain.com
NEXTAUTH_SECRET=your_production_nextauth_secret_here_minimum_32_characters_very_secure

# Next.js
NEXT_TELEMETRY_DISABLED=1
