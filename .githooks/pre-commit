#!/bin/bash
# Git pre-commit hook to prevent committing sensitive files
# Install this hook with: chmod +x .git/hooks/pre-commit

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🔒 Security Check - Pre-commit Hook${NC}"

# Check for sensitive files
SENSITIVE_FILES=(
    ".env"
    ".env.local"
    ".env.*.local"
    "*.key"
    "*.pfx"
    "*.pem"
    "appsettings.json"
)

FOUND_SENSITIVE=0

for file in "${SENSITIVE_FILES[@]}"; do
    if git diff --cached --name-only | grep -q "$file"; then
        echo -e "${RED}✗ ERRO: Tentativa de fazer commit de arquivo sensível: $file${NC}"
        FOUND_SENSITIVE=1
    fi
done

# Check for common secret patterns
if git diff --cached | grep -i -E "(password|secret|api_key|token|credentials)" > /dev/null; then
    echo -e "${YELLOW}⚠ Aviso: Possível segredo detectado no código${NC}"
    echo "Revise seu commit com: git diff --cached"
    read -p "Deseja continuar? (s/n) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Ss]$ ]]; then
        echo -e "${RED}Commit cancelado.${NC}"
        exit 1
    fi
fi

if [ $FOUND_SENSITIVE -eq 1 ]; then
    echo -e "${RED}Commit cancelado por motivos de segurança.${NC}"
    echo ""
    echo "Por favor:"
    echo "1. Execute: git reset HEAD <arquivo>"
    echo "2. Adicione o arquivo ao .gitignore"
    echo "3. Use .env.example para armazenar valores padrão"
    echo ""
    exit 1
fi

echo -e "${GREEN}✓ Verificações de segurança OK${NC}"
exit 0
